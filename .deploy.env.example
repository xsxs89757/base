# ===========================================
# 部署配置 - 复制此文件为 .deploy.env 并填入实际值
# ===========================================

# SSH 连接
SSH_HOST=your-server-ip
SSH_PORT=22
SSH_USER=root
SSH_PASS=your-password

# 远程目录
REMOTE_SERVER_DIR=/opt/app/server
REMOTE_WEB_DIR=/opt/app/web

# 部署后是否自动重启服务 (yes/no)
AUTO_RESTART=yes
# systemd 服务名 (不存在时自动创建)
SERVICE_NAME=admin-server

# Go 编译后的二进制名
SERVER_BIN_NAME=server

# 前端打包命令
WEB_BUILD_CMD="pnpm build:antd"
