# ===========================================
# 部署配置 - 复制此文件为 .deploy.env 并填入实际值
#
# 多个基于 base 的项目发布到同一台服务器:
#   每个项目拷贝在自己的 .deploy.env 里设置独立的
#   PROJECT_NAME 和 REMOTE_*_DIR 即可互不冲突。
#
# 同一份仓库维护多套发布目标(如测试/生产):
#   复制为 .deploy.<名字>.env，用 ./deploy.sh all <名字>
#   或 make release PROJECT=<名字> 选择。
# ===========================================

# 项目标识（必填，改成你自己的项目名！）
# 同一台服务器上的多个项目全靠它区分：决定默认 systemd 服务名
# <项目名>-server、远程目录归属校验、构建目录和临时包命名
PROJECT_NAME=myproject

# SSH 连接
SSH_HOST=your-server-ip
SSH_PORT=22
SSH_USER=root
SSH_PASS=your-password

# 远程目录（每个项目必须用独立目录，不能共用；部署时会校验目录归属）
REMOTE_SERVER_DIR=/opt/myproject/server
REMOTE_ADMIN_DIR=/opt/myproject/admin

# 部署后是否自动重启服务 (yes/no)
AUTO_RESTART=yes
# systemd 服务名 (不存在时自动创建；默认 <项目名>-server，多项目时无需手动区分)
#SERVICE_NAME=admin-server

# Go 编译后的二进制名
SERVER_BIN_NAME=server

# 前端打包命令
ADMIN_BUILD_CMD="pnpm build:antd"

# ── 下游扩展目标 ──────────────────────────
# 仓库根存在 deploy.project.sh 时，其声明的额外部署目标可能需要
# 额外变量（如 REMOTE_<目标>_DIR），参见该文件头部注释。
